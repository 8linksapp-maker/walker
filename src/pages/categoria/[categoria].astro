---
import { BLOG_BASE } from '../../lib/postUrl';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import { readData } from '../../lib/readData';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  function slugify(s) {
    return String(s || '').toLowerCase()
      .normalize('NFD').replace(/[̀-ͯ]/g, '')
      .replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)+/g, '');
  }
  const categoriesData = readData('categories.json', []);
  const posts = await getCollection('blog');

  // Normaliza schema misto (strings OU {name, slug}) em [{name, slug}]
  const allCats = (Array.isArray(categoriesData) ? categoriesData : []).map((c) => {
    if (c && typeof c === 'object' && c.name) return { name: String(c.name), slug: String(c.slug || slugify(c.name)) };
    if (typeof c === 'string' && c.trim()) return { name: c.trim(), slug: slugify(c) };
    return null;
  }).filter(Boolean);

  // Adiciona slugs órfãos (em posts mas não em categories.json)
  const known = new Set();
  allCats.forEach(c => { known.add(c.slug); known.add(c.name); });
  for (const p of posts) {
    const cat = p.data.category;
    if (!cat || known.has(cat)) continue;
    const s = slugify(cat);
    if (!known.has(s)) {
      allCats.push({ name: cat, slug: s });
      known.add(s); known.add(cat);
    }
  }

  return allCats.map(cat => ({
    params: { categoria: cat.slug },
    props: { categoryName: cat.name, categorySlug: cat.slug },
  }));
}

const { categoryName, categorySlug } = Astro.props;
const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
// Matching flexível: post.data.category pode ser o nome OU o slug
function slug(s) {
  return String(s || '').toLowerCase()
    .normalize('NFD').replace(/[̀-ͯ]/g, '')
    .replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)+/g, '');
}
const posts = allPosts.filter(p => {
  const c = p.data.category || '';
  return c === categoryName || c === categorySlug || slug(c) === categorySlug;
});
---

<BaseLayout title={categoryName} description={`Artigos sobre ${categoryName}`}>

  <!-- page header -->
  <section class="page-header">
    <div class="container-xl">
      <div class="text-center">
        <h1 class="mt-0 mb-2">{categoryName}</h1>
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb justify-content-center mb-0">
            <li class="breadcrumb-item"><a href="/">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">{categoryName}</li>
          </ol>
        </nav>
      </div>
    </div>
  </section>

  <!-- section main content -->
  <section class="main-content">
    <div class="container-xl">
      <div class="row gy-4">

        <div class="col-lg-8">
          {posts.length === 0 && (
            <div class="bordered rounded padding-30 text-center">
              <p>Nenhum artigo nesta categoria ainda.</p>
            </div>
          )}

          <div class="row gy-4">
            {posts.map(post => (
              <div class="col-sm-6">
                <div class="post post-grid rounded bordered">
                  <div class="thumb top-rounded">
                    <a href={`/categoria/${categorySlug}`} class="category-badge position-absolute">{categoryName}</a>
                    <a href={`${BLOG_BASE}/${post.slug}`}>
                      <div class="inner">
                        {post.data.heroImage ? (
                          <img src={post.data.heroImage} alt={post.data.title} />
                        ) : (
                          <div style="background: #f5f5f5; width: 100%; height: 200px;"></div>
                        )}
                      </div>
                    </a>
                  </div>
                  <div class="details">
                    <ul class="meta list-inline mb-0">
                      <li class="list-inline-item">
                        {post.data.pubDate.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}
                      </li>
                    </ul>
                    <h5 class="post-title mb-3 mt-3"><a href={`${BLOG_BASE}/${post.slug}`}>{post.data.title}</a></h5>
                    {post.data.description && (
                      <p class="excerpt mb-0">{post.data.description}</p>
                    )}
                  </div>
                  <div class="post-bottom clearfix d-flex align-items-center">
                    <div class="social-share me-auto">
                      <button class="toggle-button icon-share"></button>
                      <ul class="icons list-unstyled list-inline mb-0">
                        <li class="list-inline-item"><a href="#"><i class="fab fa-facebook-f"></i></a></li>
                        <li class="list-inline-item"><a href="#"><i class="fab fa-twitter"></i></a></li>
                        <li class="list-inline-item"><a href="#"><i class="fab fa-linkedin-in"></i></a></li>
                        <li class="list-inline-item"><a href="#"><i class="fab fa-pinterest"></i></a></li>
                        <li class="list-inline-item"><a href="#"><i class="fab fa-telegram-plane"></i></a></li>
                        <li class="list-inline-item"><a href="#"><i class="far fa-envelope"></i></a></li>
                      </ul>
                    </div>
                    <div class="more-button float-end">
                      <a href={`${BLOG_BASE}/${post.slug}`}><span class="icon-options"></span></a>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="col-lg-4">
          <Sidebar />
        </div>

      </div>
    </div>
  </section>

</BaseLayout>
