---
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import EmailInlineBanner from '../plugins/email-list/EmailInlineBanner.astro';
import AffiliateProducts from '../plugins/affiliates/AffiliateProducts.astro';
import PostSchemaPlugins from '../plugins/_slots/PostSchemaPlugins.astro';
import PostBottomPlugins from '../plugins/_slots/PostBottomPlugins.astro';
import PostAfterPlugins from '../plugins/_slots/PostAfterPlugins.astro';
import SocialShare from '../plugins/social-share/SocialShare.astro';
import { getCollection } from 'astro:content';
import { readData } from '../lib/readData';
import { BLOG_BASE } from '../lib/postUrl';

const authorsData = readData('authors.json', []);
const pluginsConfig = readData('pluginsConfig.json', {}) as any;
const inlineConfig = pluginsConfig?.emailList?.inline;
const inlineEnabled = inlineConfig?.enabled === true;
const inlinePosition = Number(inlineConfig?.position ?? 3);

export async function getStaticPaths() {
  const RESERVED = new Set(['blog', 'sobre', 'contato', 'categoria', 'admin', 'login', 'registrar', 'politica-privacidade', 'termos', 'configuracoes']);
  const siteConfig = readData('siteConfig.json', {}) as any;
  if (siteConfig.postUrlPrefix === 'blog') return [];
  const posts = await getCollection('blog');
  return posts
    .filter(p => !p.data.draft && !RESERVED.has(p.slug))
    .map(post => ({ params: { slug: post.slug }, props: post }));
}

const post = Astro.props;
const { Content } = await post.render();

const currentAuthor = authorsData.find((a: any) => a.id === post.data.author) || authorsData[0] || {
  name: 'Equipe', role: 'Redação', avatar: '', bio: ''
};

const categorySlug = post.data.category ? post.data.category.toLowerCase().replace(/[^a-z0-9]/g, '-') : '';
const siteConfig = readData('siteConfig.json', {}) as any;
const postUrl = `${siteConfig.url || Astro.url.origin}${BLOG_BASE}/${post.slug}`;
---

<BaseLayout title={post.data.title} description={post.data.description} image={post.data.heroImage} type="article">
  <PostSchemaPlugins
    title={post.data.title}
    description={post.data.description || ''}
    url={postUrl}
    image={post.data.heroImage}
    datePublished={post.data.pubDate instanceof Date ? post.data.pubDate.toISOString() : post.data.pubDate}
    authorName={currentAuthor?.name}
    category={post.data.category}
  />

  <section class="main-content mt-3">
    <div class="container-xl">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><a href="/">Home</a></li>
          {post.data.category && (
            <li class="breadcrumb-item"><a href={`/categoria/${categorySlug}`}>{post.data.category}</a></li>
          )}
          <li class="breadcrumb-item active" aria-current="page">{post.data.title}</li>
        </ol>
      </nav>

      <div class="row gy-4">
        <div class="col-lg-8" style="min-width:0;">
          <div class="post post-single">
            <div class="post-header">
              <h1 class="title mt-0 mb-3">{post.data.title}</h1>
              <ul class="meta list-inline mb-0">
                <li class="list-inline-item">
                  {currentAuthor.avatar ? (
                    <a href="#"><img src={currentAuthor.avatar} class="author" alt={currentAuthor.name} />{currentAuthor.name}</a>
                  ) : (
                    <a href="#">{currentAuthor.name}</a>
                  )}
                </li>
                {post.data.category && (
                  <li class="list-inline-item"><a href={`/categoria/${categorySlug}`}>{post.data.category}</a></li>
                )}
                <li class="list-inline-item post-date">
                  {post.data.pubDate.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}
                </li>
              </ul>
            </div>
            {post.data.heroImage && (
              <div class="featured-image">
                <img src={post.data.heroImage} alt={post.data.title} />
              </div>
            )}
            <div class="post-content clearfix">
              <Content />
            </div>
            {inlineEnabled && (
              <div id="email-inline-source" data-position={inlinePosition} style="display:none">
                <EmailInlineBanner />
              </div>
            )}
            <AffiliateProducts />
            <div class="post-bottom">
              <div class="row d-flex align-items-center">
                <div class="col-md-6 col-12 text-center text-md-start">
                  {post.data.category && (
                    <a href={`/categoria/${categorySlug}`} class="tag">#{post.data.category}</a>
                  )}
                </div>
                <div class="col-md-6 col-12 float-md-end">
                  <PostBottomPlugins title={post.data.title} />
                </div>
              </div>
            </div>
          </div>

          <div class="spacer" data-height="50"></div>

          <div class="about-author padding-30 rounded">
            <div class="thumb">
              {currentAuthor.avatar ? (
                <img src={currentAuthor.avatar} alt={currentAuthor.name} />
              ) : (
                <div style="width:80px;height:80px;background:#f5f5f5;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:2rem;color:#8F9BAD;">
                  {currentAuthor.name.charAt(0)}
                </div>
              )}
            </div>
            <div class="details">
              <h4 class="name"><a href="#">{currentAuthor.name}</a></h4>
              {currentAuthor.role && <span style="color:var(--walker-primary);font-size:0.85rem;">{currentAuthor.role}</span>}
              {currentAuthor.bio && <p>{currentAuthor.bio}</p>}
              <SocialShare title={post.data.title} context="author-box" />
            </div>
          </div>

          <div class="spacer" data-height="50"></div>

          <PostAfterPlugins
            currentSlug={post.slug}
            category={post.data.category || ''}
          />

          <div class="spacer" data-height="50"></div>
        </div>

        <div class="col-lg-4">
          <Sidebar />
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
  (function() {
    var postContent = document.querySelector('.post-content');
    if (!postContent) return;
    var walker = document.createTreeWalker(postContent, NodeFilter.SHOW_TEXT, null);
    var node;
    while ((node = walker.nextNode())) {
      if (node.nodeValue && node.nodeValue.indexOf(' ') !== -1) {
        node.nodeValue = node.nodeValue.replace(/ /g, ' ');
      }
    }
  })();
  </script>

  {inlineEnabled && (
    <script>
    (function() {
      const source = document.getElementById('email-inline-source');
      if (!source) return;
      const pos = Number((source as HTMLElement).dataset.position) || 3;
      const paragraphs = document.querySelectorAll('.post-content > p');
      const target = paragraphs[pos - 1] || paragraphs[paragraphs.length - 1];
      if (target) {
        target.insertAdjacentElement('afterend', source);
        source.style.display = 'block';
      }
    })();
    </script>
  )}

</BaseLayout>
